    "INTERNAL_MODULES": {
        "factory_slag": {
            "name": "精炼厂",
            "type": "factory",
            "desc": "安装在空间站内置槽位的小型生产设施，用于将小行星碎片粗炼为精炼矿渣。",
            "recipe": {
                "_comment": "消耗：1000 小行星碎块 -> 产出：2000 精炼矿渣，500 稀土",
                "inputs": {
                    "asteroid_fragment": 1000
                },
                "outputs": {
                    "refined_slag": 2000,
                    "rare_earth": 500
                },
                "cycleTime": 100 
            }
        },
        "factory_smelter": {
